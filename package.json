{
  "name": "signalatlas-v3",
  "version": "1.0.0",
  "description": "SignalAtlas v3 - Generic multi-source feed pipeline with Redis caching",
  "type": "module",
  "scripts": {
    "seed": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/seed-feeds.mjs",
    "seed:rss": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/seed-feeds.mjs --type=RSS,XML/RSS,Atom",
    "seed:json": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/seed-feeds.mjs --type=REST API,JSON API,GeoJSON",
    "seed:csv": "NODE_OPTIONS=--max-old-space-size=4096 node scripts/seed-feeds.mjs --type=CSV,CSV/API",
    "api": "NODE_OPTIONS=--max-old-space-size=4096 node server/index.js",
    "start": "npm run api"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "csv-parse": "^5.5.3",
    "fast-xml-parser": "^4.3.4",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2"
  }
}
